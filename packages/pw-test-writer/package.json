{
  "name": "@playwright/test-writer",
  "version": "0.1.0",
  "description": "AI-powered Playwright test writer CLI",
  "type": "module",
  "bin": {
    "pw-test-writer": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp src/runner/captureHook.cjs dist/runner/",
    "dev": "tsc --watch",
    "dev:run": "node --watch --no-warnings dist/cli.js",
    "start": "node --no-warnings dist/cli.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@playwright/test": "file:../playwright-test",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "ora": "^8.0.0",
    "ansi-escapes": "^7.0.0",
    "cli-cursor": "^5.0.0",
    "log-update": "^6.1.0",
    "playwright": "file:../playwright",
    "playwright-core": "file:../playwright-core"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
